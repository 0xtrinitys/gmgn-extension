{
  "manifest_version": 3,
  "name": "GMGN Full Chart",
  "version": "1.1",
  "description": "Redirects GMGN token clicks to your main chart tab instead of inline popup",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://gmgn.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {}
}
